# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Serveur MCP ─────────────────────────────────────────────────────
# Nom affiché du serveur dans les clients MCP (ex: Claude Desktop, MCP Inspector)
MCP_SERVER_NAME=ruckus-vsz-mcp

# Version du serveur (doit correspondre à la version dans pyproject.toml)
MCP_SERVER_VERSION=0.1.0

# Transport : stdio | sse | streamable-http
MCP_TRANSPORT=streamable-http

# Adresse de bind — 0.0.0.0 pour Docker, 127.0.0.1 pour local
MCP_HOST=0.0.0.0

# Port HTTP pour les transports sse / streamable-http
MCP_PORT=8081

# (Optionnel) Clé API Bearer pour sécuriser les transports HTTP
# MCP_API_KEY=

# (Optionnel) Liste CIDR autorisées, séparées par des virgules
# MCP_ALLOWED_IPS=

# Niveau de verbosité des logs — valeurs acceptées : DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Connexion Ruckus vSZ ────────────────────────────────────────────
# Identifiants API communs à tous les contrôleurs vSZ
# (le host est fourni par outil — permet le multi-contrôleur)
VSZ_USERNAME=admin
VSZ_PASSWORD=your_password_here

# Vérification du certificat SSL (false = auto-signé, true = CA valide)
VSZ_VERIFY_SSL=false

# Timeout des requêtes API en secondes
VSZ_TIMEOUT=30
