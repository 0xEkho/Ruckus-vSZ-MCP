# Copy this file to .env and fill in the values
# cp .env.example .env

# Nom affiché du serveur dans les clients MCP (ex: Claude Desktop, MCP Inspector)
MCP_SERVER_NAME=mcp-server

# Version du serveur (doit correspondre à la version dans pyproject.toml)
MCP_SERVER_VERSION=0.1.0

# Niveau de verbosité des logs — valeurs acceptées : DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Ajoutez vos clés API et variables de configuration ci-dessous
# Ces variables doivent être lues dans src/ via os.getenv("MA_VARIABLE")
# EXAMPLE_API_KEY=your_api_key_here
# EXAMPLE_API_BASE_URL=https://api.example.com
